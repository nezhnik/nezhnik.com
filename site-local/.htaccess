# nezhnik.com — Apache (Reg.ru Linux hosting)
# Канонический домен: https://nezhnik.com (без www)

RewriteEngine On
RewriteBase /

# HTTP → HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# www → apex (без www)
RewriteCond %{HTTP_HOST} ^www\.nezhnik\.com$ [NC]
RewriteRule ^ https://nezhnik.com%{REQUEST_URI} [R=301,L]

RewriteRule ^raf-servicedesk\.html$ /servicedesk [R=301,L]
RewriteRule ^raf-servicedesk/?$ /servicedesk [R=301,L]

# index.html → /
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^index$ / [R=301,L]

# *.html → clean URL (внешний 301)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# clean URL → файл .html (внутренний rewrite)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
